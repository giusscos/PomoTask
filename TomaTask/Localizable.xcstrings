    "Progressive Timer helps you discover how long you can truly focus — then gently stretch that edge." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer hilft dir zu entdecken, wie lange du dich wirklich konzentrieren kannst — und dehnt diese Grenze sanft."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer te ayuda a descubrir cuánto puedes concentrarte de verdad — y luego estira esa frontera con suavidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer vous aide à découvrir combien de temps vous pouvez vraiment vous concentrer — puis à étirer doucement cette limite."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer ti aiuta a scoprire quanto riesci davvero a concentrarti — poi allarga quel limite con delicatezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timerは、本当に集中できる時間を見つけ、その限界をやさしく伸ばします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer는 정말 집중할 수 있는 시간을 찾고, 그 한계를 부드럽게 늘려 줍니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer helpt je ontdekken hoe lang je écht kunt focussen — en rek die grens dan zachtjes op."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Progressive Timer ajuda você a descobrir por quanto tempo consegue se concentrar de verdade — e depois estende esse limite com cuidado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer 帮你发现真正能专注多久，再温和地拉长这个上限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progressive Timer 幫你發現真正能專注多久，再溫和地拉長這個上限。"
          }
        }
      }
    },
