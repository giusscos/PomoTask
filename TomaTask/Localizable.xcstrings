    "Start or pause a Progressive focus session from your Home Screen." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte oder pausiere eine Progressive-Fokus-Sitzung vom Home-Bildschirm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia o pausa una sesión Progressive desde la pantalla de inicio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Démarrez ou mettez en pause une session Progressive depuis l’écran d’accueil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avvia o metti in pausa una sessione Progressive dalla Home."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホーム画面からProgressive集中セッションを開始または一時停止。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "홈 화면에서 Progressive 집중 세션을 시작하거나 일시정지하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start of pauzeer een Progressive-focussessie vanaf je beginscherm."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicie ou pause uma sessão Progressive na Tela de Início."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从主屏幕开始或暂停 Progressive 专注会话。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從主畫面開始或暫停 Progressive 專注工作階段。"
          }
        }
      }
    },
    "Start short, grow with flow, and recover smart. Unlock Progressive with Pro." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kurz starten, mit Flow wachsen, smart erholen. Progressive mit Pro freischalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza corto, crece con el flow y recupérate con inteligencia. Desbloquea Progressive con Pro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commencez court, grandissez avec le flow, récupérez intelligemment. Débloquez Progressive avec Pro."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inizia breve, cresci con il flow e recupera in modo smart. Sblocca Progressive con Pro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短く始めて流れで伸ばし、賢く回復。ProでProgressiveを解除。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "짧게 시작하고 흐름으로 성장하며 현명하게 회복. Pro로 Progressive 잠금 해제."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begin kort, groei met de flow en herstel slim. Ontgrendel Progressive met Pro."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comece curto, cresça com o fluxo e recupere com inteligência. Desbloqueie Progressive com Pro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从短开始，随心流成长，聪明恢复。用 Pro 解锁 Progressive。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從短開始，隨心流成長，聰明恢復。用 Pro 解鎖 Progressive。"
          }
        }
      }
    },
    "Start short. Grow with flow." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
