    "Tap the button to start or pause. The dial scrolls automatically as time passes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe zum Starten oder Pausieren. Das Rad scrollt automatisch mit der Zeit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca para iniciar o pausar. El dial se mueve solo con el tiempo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez pour démarrer ou mettre en pause. Le cadran défile automatiquement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca per avviare o mettere in pausa. Il quadrante scorre da solo col tempo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ボタンで開始／一時停止。時間が進むとダイアルが自動で動きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "버튼으로 시작하거나 일시정지. 시간이 지나면 다이얼이 자동으로 움직입니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik om te starten of te pauzeren. De schijf scrollt automatisch mee met de tijd."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque para iniciar ou pausar. O disco rola automaticamente com o tempo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点按钮开始或暂停。时间流逝时旋钮会自动滚动。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點按鈕開始或暫停。時間流逝時旋鈕會自動滾動。"
          }
        }
      }
    },
    "Tap the struggle button anytime. Pause, shorten what’s left, or take a break — no guilt, just options." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe jederzeit auf den Struggle-Button. Pausieren, Rest kürzen oder Pause machen — ohne Schuldgefühle, nur Optionen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca el botón de dificultad cuando quieras. Pausa, acorta lo que queda o descansa — sin culpa, solo opciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez le bouton difficulté à tout moment. Pause, raccourcissez le reste ou prenez une pause — sans culpabilité, juste des options."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca il pulsante difficoltà in qualsiasi momento. Pausa, accorcia il resto o fai una pausa — senza sensi di colpa, solo opzioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "つらいときはいつでもボタンを。一時停止、残りを短縮、または休憩——罪悪感なし、選択肢だけ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "힘들 때 언제든 버튼을 누르세요. 일시정지, 남은 시간 줄이기, 휴식 — 죄책감 없이 선택만."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik altijd op de struggle-knop. Pauzeer, verkort wat resteert of neem een pauze — geen schuldgevoel, alleen opties."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque o botão de dificuldade a qualquer momento. Pause, encurte o restante ou faça uma pausa — sem culpa, só opções."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "随时点困难按钮。暂停、缩短剩余时间，或休息——没有愧疚，只有选择。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "隨時點困難按鈕。暫停、縮短剩餘時間，或休息——沒有愧疚，只有選擇。"
          }
        }
      }
    },
