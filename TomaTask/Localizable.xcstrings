    "Every focus block begins around 5 minutes. When you’re in the flow, the next block gets a little longer — up to 25 minutes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Fokusblock beginnt bei etwa 5 Minuten. Im Flow wird der nächste etwas länger — bis 25 Minuten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada bloque de enfoque empieza alrededor de 5 minutos. Si estás en flow, el siguiente dura un poco más — hasta 25 minutos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque bloc de focus commence vers 5 minutes. En flow, le suivant s’allonge un peu — jusqu’à 25 minutes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogni blocco di focus inizia intorno ai 5 minuti. Se sei in flow, il successivo si allunga un po’ — fino a 25 minuti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "集中ブロックは約5分から。フローに乗ると次は少し長くなり、最大25分まで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 집중 블록은 약 5분부터 시작합니다. 흐름에 타면 다음 블록이 조금 길어지며, 최대 25분까지입니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elke focusblok begint rond 5 minuten. In de flow wordt de volgende iets langer — tot 25 minuten."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada bloco de foco começa perto de 5 minutos. No fluxo, o próximo fica um pouco mais longo — até 25 minutos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个专注块大约从 5 分钟开始。进入心流后，下一块会稍长一些——最多 25 分钟。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每個專注塊大約從 5 分鐘開始。進入心流後，下一塊會稍長一些——最多 25 分鐘。"
          }
        }
      }
    },
